# Same VCH Supabase project as veteranscentralhub.us (tracker schema lives there).
# CANONICAL PROJECT REF: bszlmqdqrwqocoxbzpyh
# URL: https://bszlmqdqrwqocoxbzpyh.supabase.co
#
# DO NOT use project hlpbcmxcxgyzlmojprmp (obsolete duplicate). See .cursor/rules/supabase-tracker.mdc
#
# Copy these two lines exactly from your VCH .env — do NOT swap them.
SUPABASE_URL=
# Anon / publishable key only (VCH uses sb_publishable_... or legacy anon JWT ending in ...kZgCjYXks)
SUPABASE_ANON_KEY=
# Optional alias — must match SUPABASE_ANON_KEY if you set it:
# SUPABASE_KEY=

# Netlify: set SUPABASE_URL + SUPABASE_ANON_KEY for both Build and Production scopes, then redeploy.
# Runtime fallback aliases (optional): NUXT_PUBLIC_SUPABASE_URL, NUXT_PUBLIC_SUPABASE_KEY

# Server-only service_role key (ends in ...u2TF0y1k) — never put this in SUPABASE_ANON_KEY
SUPABASE_SERVICE_KEY=

# VCH - tracker Stripe account (separate from hub donations)
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
# Symptom Tracker Pro — annual $14.99/year
# LIVE (production charges): price_1TpVsyHw2LhhEbB99wTnbEpR
# SANDBOX: create a test-mode price in Stripe Dashboard → use that price_... id instead
STRIPE_PRO_PRICE_ID=price_1TpVsyHw2LhhEbB99wTnbEpR
STRIPE_WEBHOOK_SECRET=

# Production: https://tracker.veteranscentralhub.us
APP_URL=

# Google sign-in (Supabase VCH project → Authentication → Providers → Google):
# 1. Create OAuth client in Google Cloud Console (Web application).
# 2. Authorized redirect URI: https://bszlmqdqrwqocoxbzpyh.supabase.co/auth/v1/callback
# 3. Paste Client ID + Secret into Supabase Google provider and enable it.
# 4. Supabase → Authentication → URL Configuration:
#    Site URL: https://veteranscentralhub.us   (NOT localhost)
#    Redirect URLs (one per line):
#      https://tracker.veteranscentralhub.us/auth/callback
#      https://veteranscentralhub.us/auth/callback
#      http://localhost:3000/auth/callback
# Same auth.users pool as veteranscentralhub.us — one Google account works on both once VCH enables it too.

# Web Push (generate with: npx web-push generate-vapid-keys)
# Public key → VAPID_PUBLIC_KEY (Netlify build + runtime). Private key → VAPID_PRIVATE_KEY (server only).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# You generate this yourself (e.g. openssl rand -hex 32). Netlify → Environment variables → Production.
# Used only by the hourly reminder-cron function to call POST /api/reminders/send
REMINDER_CRON_SECRET=

# Contact form (Web3Forms) — optional; tracker falls back to the same public key as VCH contact.
# Override here or on Netlify if you use a separate Web3Forms form.
NUXT_PUBLIC_WEB3FORMS_ACCESS_KEY=

# Production checkout (tracker Stripe account — not VCH donations):
# APP_URL=https://tracker.veteranscentralhub.us
# Webhook: https://tracker.veteranscentralhub.us/api/stripe/webhook
# Events: checkout.session.completed, customer.subscription.created,
# customer.subscription.updated, customer.subscription.deleted, invoice.payment_failed
# After deploy: GET https://tracker.veteranscentralhub.us/api/health → checkoutReady: true
#   stripe listen --forward-to localhost:3000/api/stripe/webhook
# Copy the whsec_... secret from that command into STRIPE_WEBHOOK_SECRET below.
# Without stripe listen, Pro still unlocks via /api/stripe/confirm-subscription on the
# success page — but SUPABASE_SERVICE_KEY must be set in .env.
#
# Local: use sk_test_ / pk_test_ keys and a TEST-mode STRIPE_PRO_PRICE_ID (not the live price below).
# Check: http://localhost:3000/api/stripe/config-check
# Events: checkout.session.completed, customer.subscription.created,
# customer.subscription.updated, customer.subscription.deleted, invoice.payment_failed
#
# Config check (after keys are set):
# https://tracker.veteranscentralhub.us/api/stripe/config-check
