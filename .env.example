# Same VCH Supabase project as veteranscentralhub.us (tracker schema lives there).
# CANONICAL PROJECT REF: bszlmqdqrwqocoxbzpyh
# URL: https://bszlmqdqrwqocoxbzpyh.supabase.co
#
# DO NOT use project hlpbcmxcxgyzlmojprmp (obsolete duplicate). See .cursor/rules/supabase-tracker.mdc
#
# Copy these two lines exactly from your VCH .env — do NOT swap them.
SUPABASE_URL=
# Anon / publishable key only (VCH uses sb_publishable_... or legacy anon JWT ending in ...kZgCjYXks)
SUPABASE_ANON_KEY=
# Optional alias — must match SUPABASE_ANON_KEY if you set it:
# SUPABASE_KEY=

# Netlify: set SUPABASE_URL + SUPABASE_ANON_KEY for both Build and Production scopes, then redeploy.
# Runtime fallback aliases (optional): NUXT_PUBLIC_SUPABASE_URL, NUXT_PUBLIC_SUPABASE_KEY

# Server-only service_role key (ends in ...u2TF0y1k) — never put this in SUPABASE_ANON_KEY
SUPABASE_SERVICE_KEY=

# VCH - tracker Stripe account (separate from hub donations)
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
# Symptom Tracker Pro — annual $14.99/year (live catalog price; create in Stripe if missing)
STRIPE_PRO_PRICE_ID=price_1TpVsyHw2LhhEbB99wTnbEpR
STRIPE_WEBHOOK_SECRET=

# Production: https://tracker.veteranscentralhub.us
APP_URL=

# Web Push (generate with: npx web-push generate-vapid-keys)
# Public key → VAPID_PUBLIC_KEY (Netlify build + runtime). Private key → VAPID_PRIVATE_KEY (server only).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# You generate this yourself (e.g. openssl rand -hex 32). Netlify → Environment variables → Production.
# Used only by the hourly reminder-cron function to call POST /api/reminders/send
REMINDER_CRON_SECRET=
# TEST ONLY — sends a push every 5 min (ignores log hour / already-logged checks). Remove after testing.
REMINDER_TEST_MODE=false
# REMINDER_TEST_INTERVAL_MINUTES=5

# Stripe webhook endpoint (after deploy):
# https://tracker.veteranscentralhub.us/api/stripe/webhook
# Events: checkout.session.completed, customer.subscription.created,
# customer.subscription.updated, customer.subscription.deleted, invoice.payment_failed
#
# Config check (after keys are set):
# https://tracker.veteranscentralhub.us/api/stripe/config-check
